# Copy this file to "ma3.env" (normal name, easy in Finder) OR to ".env" (old convention).
# The server loads ma3.env first if it exists, else .env. Same folder as server.js.
# Speech-to-text: default order is Deepgram → OpenAI → Google Cloud (set keys you want; omit paid ones for free-only).
# Free / no billing: leave cloud keys empty — iPhone Safari uses on-device Web Speech. Or use Deepgram free credits.
# Force on-device only (ignores cloud keys for the mic UI): STT_PROVIDER=browser
# Turn off Safari speech fallback: STT_BROWSER=0
# WEB_SPEECH_LANG=en-US

# STT_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
# OPENAI_TRANSCRIBE_LANGUAGE=en

# Google Cloud Speech-to-Text (billing)
# STT_PROVIDER=google_cloud
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GOOGLE_CLOUD_KEY_JSON={"type":"service_account",...}
# GOOGLE_CLOUD_LANGUAGE=en-US
# GOOGLE_CLOUD_MODEL=latest_short

# STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=

# Deepgram tuning (default model is nova-2; try nova-3 only if your Deepgram project allows it)
# DEEPGRAM_MODEL=nova-3
# DEEPGRAM_LANGUAGE=en
# DEEPGRAM_UTTERANCES=1
# DEEPGRAM_KEYWORDS=keywords=customterm:3
# Deepgram optional flags
# DEEPGRAM_DICTATION=1
# DEEPGRAM_DIARIZE=1
# Extra Deepgram querystring to append (no leading ? needed). Example:
# DEEPGRAM_EXTRA_QUERY=endpointing=false&interim_results=true
# Live Deepgram streaming over WebSocket (interim + final) from iPhone mic:
# DEEPGRAM_LIVE=1

# Voice UX mode: tap-to-talk with auto-timeout (default) or push-to-talk
# VOICE_MODE=tap
# LISTEN_TIMEOUT_MS=6500

# --- LLM copilot (default: Gemini if GEMINI_API_KEY is set) ---
# LLM_PROVIDER=google
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Optional: force another provider if you add keys later
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
