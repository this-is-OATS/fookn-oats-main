# HTML + dynamic data: always revalidate so deploys go live instantly
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/site.js
  Cache-Control: public, max-age=0, must-revalidate
/ticker.json
  Cache-Control: public, max-age=0, must-revalidate

# Images: safe to cache hard (filenames are stable)
/images/*
  Cache-Control: public, max-age=86400
