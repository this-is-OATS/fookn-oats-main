# HTML + dynamic data: always revalidate so deploys go live instantly
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/site.js
  Cache-Control: public, max-age=0, must-revalidate
/edm-lite
  Cache-Control: public, max-age=0, must-revalidate
/edm-lite.html
  Cache-Control: public, max-age=0, must-revalidate
/live.json
  Cache-Control: public, max-age=0, must-revalidate
/ticker.json
  Cache-Control: public, max-age=0, must-revalidate
/rolled-recorded
  Cache-Control: public, max-age=0, must-revalidate
/rolled-recorded.html
  Cache-Control: public, max-age=0, must-revalidate
/rolled-recorded-event.html
  Cache-Control: public, max-age=0, must-revalidate
/rolled-recorded.json
  Cache-Control: public, max-age=0, must-revalidate
/rr-events/*
  Cache-Control: public, max-age=0, must-revalidate
/parking-garage-sessions-event.html
  Cache-Control: public, max-age=0, must-revalidate
/parking-garage-sessions-event
  Cache-Control: public, max-age=0, must-revalidate
/pgs-events/*
  Cache-Control: public, max-age=0, must-revalidate
/rent
  Cache-Control: public, max-age=0, must-revalidate
/rent.html
  Cache-Control: public, max-age=0, must-revalidate
/rent-data.js
  Cache-Control: public, max-age=0, must-revalidate

# Images: safe to cache hard (filenames are stable)
/images/*
  Cache-Control: public, max-age=86400
